# Runtime configuration for OCI Compute systemd services.
# Install target: /etc/oci-forecast/forecast.env

# Service ports on the Compute instance
ML_SERVICE_PORT=8081
ORCHESTRATOR_PORT=8080

# Chronos ML service
CHRONOS_MODEL_NAME=amazon/chronos-t5-small
CHRONOS_MODEL_REVISION=
CHRONOS_MODEL_SOURCE_URL=https://huggingface.co/amazon/chronos-t5-small
CHRONOS_DEVICE=cpu
CHRONOS_NUM_SAMPLES=100
MAX_PREDICTION_LENGTH=96

# First smoke test:
#   ML_LOAD_PUBLIC_MODEL=false
#   ML_FORCE_FALLBACK=true
# Real Chronos inference:
#   ML_LOAD_PUBLIC_MODEL=true
#   ML_FORCE_FALLBACK=false
ML_LOAD_PUBLIC_MODEL=false
ML_FORCE_FALLBACK=true

# Orchestrator -> ML service on the same Compute instance
ML_SERVICE_BASE_URL=http://127.0.0.1:8081
ML_SERVICE_TIMEOUT_SECONDS=20

# vLLM OpenAI-compatible endpoint, expected to be another OCI-hosted endpoint
VLLM_BASE_URL=http://replace-with-vllm-private-ip-or-dns:8000/v1
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_API_KEY=EMPTY
VLLM_TIMEOUT_SECONDS=10
VLLM_TEMPERATURE=0.2
VLLM_MAX_TOKENS=500

# Optional Oracle Autonomous Database logging
DB_WRITE_ENABLED=false
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=

